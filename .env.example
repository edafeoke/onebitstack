PORT=3000

APP_NAME="Central Server"
NEXT_PUBLIC_APP_NAME="Central Server"

# website = public marketing/docs (Vercel). control_plane = installable VPS app (default).
# CENTRAL_EDITION=website
# CENTRAL_EDITION=control_plane

# Public URL used in install.sh copy on the website (defaults to NEXT_PUBLIC_APP_URL)
# NEXT_PUBLIC_INSTALL_URL=https://your-brand.com

GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_SLUG=

GITHUB_WEBHOOK_SECRET=
GITHUB_APP_WEBHOOK_SECRET=

# Legacy unsigned POST /api/webhook (local dev only — default off)
# ENABLE_LEGACY_GITHUB_WEBHOOK=false

# Redis + BullMQ deployment queue (required in production). Start: docker compose up -d redis
REDIS_URL=redis://127.0.0.1:6379
# REQUIRE_REDIS_QUEUE=true   # default on when NODE_ENV=production
# Run in a second process: npm run worker:deploy

# Agent-primary deploys: no SSH fallback when agent is paired (full deploys only)
# AGENT_PRIMARY=true

# TLS health alerts when certificate expires within N days (default 14)
# SSL_EXPIRY_WARN_DAYS=14

# VPS agent JWT signing (defaults to BETTER_AUTH_SECRET if unset)
AGENT_JWT_SECRET=

# Rate limits (optional overrides)
# GITHUB_WEBHOOK_REPO_RATE_LIMIT=30
# GITHUB_PUSH_PROJECT_RATE_LIMIT=10
# DEPLOY_API_PROJECT_RATE_LIMIT=5
# DEPLOY_API_USER_RATE_LIMIT=20
# DETECT_STACK_USER_RATE_LIMIT=20
# AGENT_PAIR_IP_RATE_LIMIT=10
GITHUB_PRIVATE_KEY=

# Control plane database: postgresql (production) | sqlite (local trial)
CENTRAL_DATABASE_PROVIDER=postgresql
# PostgreSQL (control plane database)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=central
# SQLite trial example:
# CENTRAL_DATABASE_PROVIDER=sqlite
# DATABASE_URL=file:./data/central.db

NEXT_PUBLIC_APP_URL=http://localhost:3000

BETTER_AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# SaaS (default): email/password sign-up at /signup. Self-host: DEPLOYMENT_MODE=self_hosted
# DEPLOYMENT_MODE=saas
# DEPLOYMENT_MODE=self_hosted
# ENABLE_CREDENTIAL_AUTH=false

# After first GitHub sign-in, run: npm run db:seed (promotes matching user to platform admin)
PLATFORM_ADMIN_EMAIL=

# Encrypts SSH private keys at rest (32+ chars recommended)
ENCRYPTION_KEY=

# Origins allowed to iframe deployed apps in the dashboard (optional)
# CENTRAL_FRAME_ANCESTORS=http://localhost:3000
# CENTRAL_FRAME_ANCESTOR_WILDCARD=https://*.centralstackhq.com

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
