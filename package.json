{
  "name": "central-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "worker:deploy": "tsx worker/deploy-worker.ts",
    "agent:pair": "tsx packages/central-agent/src/cli.ts pair",
    "agent:run": "tsx packages/central-agent/src/cli.ts run",
    "build": "next build",
    "db:sync": "prisma db push",
    "db:push": "prisma db push",
    "start": "next start",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --update-env",
    "postinstall": "prisma generate && fumadocs-mdx",
    "install:sync": "cp scripts/install.sh public/install.sh",
    "check:install-sync": "bash scripts/check-install-sync.sh",
    "smoke:install": "bash scripts/smoke-install.sh",
    "build:website": "CENTRAL_EDITION=website npm run build",
    "central:doctor": "bash scripts/central-doctor.sh",
    "central:status": "bash scripts/central-status.sh",
    "setup:github": "bash scripts/github-app.sh",
    "db:seed": "tsx prisma/seed.ts",
    "db:bootstrap": "tsx prisma/bootstrap-central-schema.ts",
    "db:verify": "tsx prisma/verify-database.ts",
    "db:apply-patches": "tsx prisma/apply-schema-patches.ts",
    "db:migrate": "prisma migrate dev",
    "test": "node --import tsx --test 'src/**/*.test.ts' 'src/lib/**/*.test.ts'"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.4.7",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.76.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^15.0.10",
    "fumadocs-ui": "^16.9.3",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.16.0",
    "monaco-editor": "^0.52.2",
    "next": "^16.0.7",
    "next-themes": "^0.4.6",
    "p-queue": "^9.0.1",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.19.19",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/ssh2": "^1.15.5",
    "postcss": "^8.5.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.22.0",
    "typescript": "^5.8.3"
  }
}
