.vercel

# Prisma — generated client (regenerate with prisma generate)
/src/generated/prisma

# Local databases & SQLite artifacts
*.db
*.db-journal
*.db-wal
*.db-shm

# TypeScript / tooling
*.tsbuildinfo
.turbo

# Debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Test / coverage
coverage/
.nyc_output/

# IDE (optional; remove if your team commits these)
.idea/
